# =============================================================================
# Default — auto-detect text files; store as LF in repo; check out as LF
# =============================================================================
* text=auto eol=lf

# =============================================================================
# Source code — explicit LF (overrides any user-level autocrlf setting)
# =============================================================================
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.sh    text eol=lf

# =============================================================================
# Windows-specific files — must keep CRLF or they break
# =============================================================================
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# =============================================================================
# Binary files — never normalize
# =============================================================================
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.db    binary
*.sqlite binary
*.sqlite3 binary
