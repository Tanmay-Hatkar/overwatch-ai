# =============================================================================
# Overwatch backend — environment variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit your real keys.

# ---------------------------------------------------------------------------
# LLM providers — fallback chain order: OpenAI -> Groq -> Ollama
# At least one provider must be configured. Ollama works without a key but
# requires Ollama running locally with a model installed.
# ---------------------------------------------------------------------------

# OpenAI (primary, paid, best quality)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (fast, free tier, OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local, free, requires `ollama serve` running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# LLM behavior
# ---------------------------------------------------------------------------

# Default temperature for creative tasks (briefings, free-form replies)
LLM_TEMPERATURE=0.7

# Temperature for structured output (intent parsing) — keep at 0 for determinism
LLM_INTENT_TEMPERATURE=0.0

# Max tokens per response (prevents runaway costs)
LLM_MAX_TOKENS=500
