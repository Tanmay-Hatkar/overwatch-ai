# =============================================================================
# Overwatch backend — environment variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit your real keys.

# ---------------------------------------------------------------------------
# LLM providers — fallback chain order: OpenAI -> Groq -> Ollama
# At least one provider must be configured. Ollama works without a key but
# requires Ollama running locally with a model installed.
# ---------------------------------------------------------------------------

# OpenAI (primary, paid, best quality)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (fast, free tier, OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local, free, requires `ollama serve` running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# LLM behavior
# ---------------------------------------------------------------------------

# Default temperature for creative tasks (briefings, free-form replies)
LLM_TEMPERATURE=0.7

# Temperature for structured output (intent parsing) — keep at 0 for determinism
LLM_INTENT_TEMPERATURE=0.0

# Max tokens per response (prevents runaway costs)
LLM_MAX_TOKENS=500

# ---------------------------------------------------------------------------
# Web Push notifications (VAPID)
# ---------------------------------------------------------------------------
# Generate a keypair once: python -c "..." (see scripts/generate_vapid.py)
# Public key goes to the frontend (via /push/vapid-public-key endpoint).
# Private key signs push payloads; keep secret.
# Subject is a mailto: URL identifying the app owner (required by VAPID spec).

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# How often the reminder scheduler checks for newly-overdue commitments (seconds)
REMINDER_POLL_INTERVAL_SECONDS=60
