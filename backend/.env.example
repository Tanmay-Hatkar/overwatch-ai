# =============================================================================
# Overwatch backend — environment variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit your real keys.

# ---------------------------------------------------------------------------
# LLM providers — fallback chain order: OpenAI -> Groq -> Ollama
# At least one provider must be configured. Ollama works without a key but
# requires Ollama running locally with a model installed.
# ---------------------------------------------------------------------------

# OpenAI (primary, paid, best quality)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (fast, free tier, OpenAI-compatible)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local, free, requires `ollama serve` running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# LLM behavior
# ---------------------------------------------------------------------------

# Default temperature for creative tasks (briefings, free-form replies)
LLM_TEMPERATURE=0.7

# Temperature for structured output (intent parsing) — keep at 0 for determinism
LLM_INTENT_TEMPERATURE=0.0

# Max tokens per response (prevents runaway costs)
LLM_MAX_TOKENS=500

# ---------------------------------------------------------------------------
# Web Push notifications (VAPID)
# ---------------------------------------------------------------------------
# Generate a keypair once: python -c "..." (see scripts/generate_vapid.py)
# Public key goes to the frontend (via /push/vapid-public-key endpoint).
# Private key signs push payloads; keep secret.
# Subject is a mailto: URL identifying the app owner (required by VAPID spec).

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# How often the reminder scheduler checks for newly-overdue commitments (seconds)
REMINDER_POLL_INTERVAL_SECONDS=60

# ---------------------------------------------------------------------------
# Authentication (Google OAuth + JWT sessions)
# ---------------------------------------------------------------------------
# Get GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET from Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Add http://localhost:8000/auth/google/callback as an "Authorized redirect URI"
# on the same OAuth 2.0 Client ID used for calendar/gmail access.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# HS256 signing key for JWT session cookies. MUST be at least 32 random chars.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Public URL of this backend (used to build the OAuth redirect_uri).
# In production, set to the actual deployed URL (e.g. https://overwatch.up.railway.app).
BACKEND_URL=http://localhost:8000

# Public URL of the frontend (used for post-login redirect + CORS allow-list).
# In production, set to e.g. https://overwatch.vercel.app.
FRONTEND_URL=http://localhost:5173

# environment=production turns on the cookie Secure flag (HTTPS only).
# Leave as "development" for local dev (browser would refuse cookies otherwise).
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Production hardening
# ---------------------------------------------------------------------------

# Comma-separated origins allowed for browser CORS. Must include the frontend's
# URL exactly (scheme + host + port). Wildcards aren't allowed because we use
# credentials: 'include' on every fetch.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Comma-separated email allowlist for sign-in. Empty = open signup.
# For a private single-user deploy, set this to YOUR email only — anyone else
# who attempts to sign in is redirected with ?auth_error=email_not_allowed.
ALLOWED_GOOGLE_EMAILS=

# Absolute path to the SQLite DB file. Empty = backend/data/overwatch.db (dev).
# On Railway, set to /data/overwatch.db (the volume mount point) so the DB
# survives container restarts.
DATABASE_PATH=

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
