<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link for the OAuth callback: overwatch://auth?token=...
                 The system browser redirects here after Google sign-in so
                 the app can capture the session token (see lib/native.js). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="overwatch" android:host="auth" />
            </intent-filter>

            <!-- Deep link for home-screen widget row taps (ADR-0020):
                 overwatch://commitment/{id}. Reuses the same "overwatch"
                 custom scheme already registered above for the OAuth
                 callback rather than inventing a second mechanism. v1 just
                 opens the app on this route; wiring the SPA to navigate to
                 the specific commitment is a frontend follow-up. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="overwatch" android:host="commitment" />
            </intent-filter>

        </activity>

        <!-- Home-screen widget (ADR-0020): commitment list. Exported=true
             because the AppWidgetHost (the launcher, a different app) is
             what sends the APPWIDGET_UPDATE broadcast this receiver
             listens for. -->
        <receiver
            android:name=".widget.CommitmentWidgetReceiver"
            android:exported="true"
            android:label="@string/commitment_widget_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/commitment_widget_info" />
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Tier-2 ring escalation (ADR-0019): full-screen "the phone actually
             rings" alarm shown when a Tier-1 reminder was ignored. -->
        <activity
            android:name=".RingActivity"
            android:theme="@style/AppTheme.Ring"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:exported="false" />

        <receiver android:name=".RingAlarmReceiver" android:exported="false" />
        <receiver android:name=".RingActionReceiver" android:exported="false" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Local notification reminders (commitment alarms) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Tier-2 ring escalation (ADR-0019): full-screen alarm on Android 14+ -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Voice input (native speech recognition) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Allow querying the device speech-recognition service (Android 11+) -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>
</manifest>
