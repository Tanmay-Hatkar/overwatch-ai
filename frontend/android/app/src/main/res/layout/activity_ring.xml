<?xml version="1.0" encoding="utf-8"?>
<!-- Tier-2 full-screen ring UI (ADR-0019). Plain Views (no Compose dependency
     needed) — commitment text plus Snooze/Done, matching the Tier-1 actions. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A0F00">

    <TextView
        android:id="@+id/ringTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:paddingBottom="16dp"
        tools:text="Overwatch" />

    <TextView
        android:id="@+id/ringBody"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#F5A623"
        android:gravity="center"
        android:paddingBottom="48dp"
        tools:text="Time to start: call the dentist" />

    <Button
        android:id="@+id/ringDone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Mark done" />

    <Button
        android:id="@+id/ringSnooze"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Snooze 10 min" />

</LinearLayout>
